# 複製這個檔成 keystore.properties，填入你的密碼後再 build。
# keystore.properties 已被 .gitignore 排除，不會進版控。
#
# storeFile 可填絕對路徑。下面預設指向你 sudoku-app 的 upload keystore；
# 若想為「單字怪物」用獨立的金鑰，請另外 keytool 產生一把再改這裡。
storeFile=/Users/michael/sudoku-app-keys/upload-keystore.jks
storePassword=你的_KEYSTORE_密碼
keyAlias=upload
keyPassword=你的_KEY_密碼
